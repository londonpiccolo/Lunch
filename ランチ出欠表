では、別の方法でいきましょう。コードを直接コピーしてファイルを作る方法です。

---

## 手順

1. 下のコードを**全選択してコピー**（コードの右上にコピーボタンがあります）
2. PCの**メモ帳**（Windowsの場合）を開く
3. コピーしたものを**貼り付け**
4. 「名前を付けて保存」→ファイル名を `index.html`、文字コードを `UTF-8` にして保存

---

```html
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ランチ出欠表</title>
  <meta name="theme-color" content="#ff7a3d" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="ランチ出欠表" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23ff7a3d'/><text y='72' x='50' text-anchor='middle' font-size='60'>🍱</text></svg>" />
  <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23ff7a3d'/><text y='72' x='50' text-anchor='middle' font-size='60'>🍱</text></svg>" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #fff8f0 0%, #ffeedd 100%);
      font-family: 'Hiragino Sans', 'Meiryo', sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 32px 16px 64px;
    }
    .title {
      background: #ff7a3d;
      color: white;
      border-radius: 16px;
      padding: 16px 40px;
      margin-bottom: 28px;
      box-shadow: 0 4px 16px rgba(255,122,61,0.3);
      font-size: 22px;
      font-weight: bold;
      letter-spacing: 0.1em;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .summary {
      display: flex;
      gap: 16px;
      margin-bottom: 24px;
    }
    .summary-card {
      border-radius: 12px;
      padding: 12px 20px;
      text-align: center;
      min-width: 80px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    }
    .summary-count { font-size: 22px; font-weight: bold; }
    .summary-label { font-size: 12px; color: #666; margin-top: 2px; }
    .list {
      background: white;
      border-radius: 18px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.10);
      overflow: hidden;
      width: 100%;
      max-width: 380px;
    }
    .member-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid #f5f0eb;
      cursor: pointer;
      transition: background 0.15s;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }
    .member-row:last-child { border-bottom: none; }
    .member-row:active { background: #fff3ec; }
    .member-name { font-size: 17px; font-weight: 500; color: #333; }
    .status-badge {
      font-size: 22px;
      min-width: 40px;
      text-align: center;
      transition: transform 0.1s;
    }
    .member-row:active .status-badge { transform: scale(0.85); }
    .hint {
      margin-top: 18px;
      font-size: 12px;
      color: #aaa;
      text-align: center;
    }
    .reset-btn {
      margin-top: 24px;
      background: white;
      border: 2px solid #ff7a3d;
      color: #ff7a3d;
      border-radius: 12px;
      padding: 12px 36px;
      font-size: 15px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.15s;
      font-family: inherit;
    }
    .reset-btn:hover { background: #fff3ec; }
    .reset-btn:active { background: #ff7a3d; color: white; }
    .saved-notice {
      margin-top: 12px;
      font-size: 11px;
      color: #bbb;
      text-align: center;
      opacity: 0;
      transition: opacity 0.5s;
    }
    .saved-notice.show { opacity: 1; }
  </style>
</head>
<body>
<div class="title">🍱 ランチ出欠表</div>
<div class="summary">
  <div class="summary-card" style="background:#e8f5e9;">
    <div class="summary-count" style="color:#4CAF50;" id="count-o">0</div>
    <div class="summary-label">◯ 参加</div>
  </div>
  <div class="summary-card" style="background:#ffebee;">
    <div class="summary-count" style="color:#e53935;" id="count-x">0</div>
    <div class="summary-label">☓ 不参加</div>
  </div>
  <div class="summary-card" style="background:#f5f5f5;">
    <div class="summary-count" style="color:#9e9e9e;" id="count-pending">0</div>
    <div class="summary-label">－ 未回答</div>
  </div>
</div>
<div class="list" id="member-list"></div>
<p class="hint">✏️ 名前をタップすると「◯ → ☓ → 未回答」と切り替わります</p>
<button class="reset-btn" id="reset-btn">🔄 出欠リセット</button>
<div class="saved-notice" id="saved-notice">💾 保存しました</div>
<script>
  if ("serviceWorker" in navigator) {
    navigator.serviceWorker.getRegistrations().then(function(registrations) {
      for (let reg of registrations) { reg.unregister(); }
    });
  }
  const MEMBERS = [
    "愛美", "岩男", "すみれ", "守屋", "なつ",
    "斎藤", "かこ", "谷", "飯尾", "美奈",
    "いづみ", "好美", "影山"
  ];
  const STORAGE_KEY = "lunch-statuses-v2";
  const CYCLE = [null, "◯", "☓"];
  function loadStatuses() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      return saved ? JSON.parse(saved) : {};
    } catch(e) { return {}; }
  }
  function saveStatuses(statuses) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(statuses)); } catch(e) {}
    const notice = document.getElementById("saved-notice");
    notice.classList.add("show");
    clearTimeout(notice._timer);
    notice._timer = setTimeout(() => notice.classList.remove("show"), 1800);
  }
  let statuses = loadStatuses();
  function render() {
    const list = document.getElementById("member-list");
    list.innerHTML = "";
    let cO = 0, cX = 0, cP = 0;
    MEMBERS.forEach(name => {
      const s = statuses[name] ?? null;
      if (s === "◯") cO++;
      else if (s === "☓") cX++;
      else cP++;
      const row = document.createElement("div");
      row.className = "member-row";
      const nameEl = document.createElement("span");
      nameEl.className = "member-name";
      nameEl.textContent = name;
      const badge = document.createElement("span");
      badge.className = "status-badge";
      if (s === "◯") {
        badge.textContent = "◯";
        badge.style.color = "#4CAF50";
        badge.style.textShadow = "0 2px 8px rgba(76,175,80,0.4)";
      } else if (s === "☓") {
        badge.textContent = "☓";
        badge.style.color = "#e53935";
        badge.style.textShadow = "0 2px 8px rgba(229,57,53,0.4)";
      } else {
        badge.textContent = "－";
        badge.style.color = "#bbb";
      }
      row.appendChild(nameEl);
      row.appendChild(badge);
      row.addEventListener("click", () => {
        const cur = statuses[name] ?? null;
        const next = CYCLE[(CYCLE.indexOf(cur) + 1) % CYCLE.length];
        if (next === null) delete statuses[name];
        else statuses[name] = next;
        saveStatuses(statuses);
        render();
      });
      list.appendChild(row);
    });
    document.getElementById("count-o").textContent = cO;
    document.getElementById("count-x").textContent = cX;
    document.getElementById("count-pending").textContent = cP;
  }
  document.getElementById("reset-btn").addEventListener("click", () => {
    if (confirm("出欠をリセットしますか？")) {
      statuses = {};
      saveStatuses(statuses);
      render();
    }
  });
  render();
</script>
</body>
</html>